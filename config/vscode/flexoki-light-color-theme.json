{
    "$schema": "vscode://schemas/color-theme",
    "name": "Flexoki Light",
    "type": "light",
    "colors": {
        "editor.background": "#FFFCF0",
        "editor.foreground": "#100F0F",
        "editor.lineHighlightBackground": "#CECDC3",
        "editor.selectionBackground": "#B7B5AC",
        "editor.selectionHighlightBackground": "#CECDC380",
        "editor.inactiveSelectionBackground": "#CECDC380",
        "editor.findMatchBackground": "#5E409D60",
        "editor.findMatchHighlightBackground": "#5E409D30",
        "editor.wordHighlightBackground": "#B7B5AC80",
        "editor.wordHighlightStrongBackground": "#B7B5ACA0",
        "editor.linkedEditingBackground": "#B7B5AC80",
        "editorCursor.foreground": "#100F0F",
        "editorWhitespace.foreground": "#B7B5AC",
        "editorIndentGuide.background1": "#CECDC3",
        "editorIndentGuide.activeBackground1": "#B7B5AC",
        "editorLineNumber.foreground": "#B7B5AC",
        "editorLineNumber.activeForeground": "#6F6E69",
        "editorBracketMatch.background": "#B7B5AC80",
        "editorBracketMatch.border": "#AD8301",
        "editorBracketHighlight.foreground1": "#205EA6",
        "editorBracketHighlight.foreground2": "#BC5215",
        "editorBracketHighlight.foreground3": "#5E409D",
        "editorBracketHighlight.foreground4": "#AD8301",
        "editorBracketHighlight.foreground5": "#24837B",
        "editorBracketHighlight.foreground6": "#A02F6F",
        "editorError.foreground": "#AF3029",
        "editorWarning.foreground": "#AD8301",
        "editorInfo.foreground": "#24837B",
        "editorHint.foreground": "#24837B",
        "editorGutter.addedBackground": "#66800B",
        "editorGutter.deletedBackground": "#AF3029",
        "editorGutter.modifiedBackground": "#205EA6",
        "editorOverviewRuler.addedForeground": "#66800B",
        "editorOverviewRuler.deletedForeground": "#AF3029",
        "editorOverviewRuler.modifiedForeground": "#205EA6",
        "editorRuler.foreground": "#E6E4D9",
        "editorCodeLens.foreground": "#6F6E69",
        "editorInlayHint.foreground": "#6F6E69",
        "editorInlayHint.background": "#F2F0E5",
        "editorStickyScroll.background": "#F2F0E5",
        "editorStickyScrollHover.background": "#E6E4D9",

        "diffEditor.insertedTextBackground": "#66800B20",
        "diffEditor.removedTextBackground": "#AF302920",
        "diffEditor.insertedLineBackground": "#66800B15",
        "diffEditor.removedLineBackground": "#AF302915",

        "foreground": "#100F0F",
        "focusBorder": "#CECDC3",
        "descriptionForeground": "#6F6E69",
        "errorForeground": "#AF3029",
        "icon.foreground": "#6F6E69",
        "selection.background": "#CECDC3",
        "widget.shadow": "#100F0F15",

        "activityBar.background": "#FFFCF0",
        "activityBar.foreground": "#100F0F",
        "activityBar.inactiveForeground": "#B7B5AC",
        "activityBar.border": "#E6E4D9",
        "activityBarBadge.background": "#205EA6",
        "activityBarBadge.foreground": "#FFFCF0",

        "sideBar.background": "#F2F0E5",
        "sideBar.foreground": "#100F0F",
        "sideBar.border": "#E6E4D9",
        "sideBarTitle.foreground": "#100F0F",
        "sideBarSectionHeader.background": "#E6E4D9",
        "sideBarSectionHeader.foreground": "#100F0F",

        "list.activeSelectionBackground": "#B7B5AC",
        "list.activeSelectionForeground": "#100F0F",
        "list.inactiveSelectionBackground": "#CECDC3",
        "list.inactiveSelectionForeground": "#100F0F",
        "list.hoverBackground": "#E6E4D9",
        "list.focusBackground": "#B7B5AC",
        "list.highlightForeground": "#AD8301",
        "list.errorForeground": "#AF3029",
        "list.warningForeground": "#AD8301",

        "tree.indentGuidesStroke": "#CECDC3",

        "titleBar.activeBackground": "#FFFCF0",
        "titleBar.activeForeground": "#100F0F",
        "titleBar.inactiveBackground": "#FFFCF0",
        "titleBar.inactiveForeground": "#B7B5AC",
        "titleBar.border": "#E6E4D9",

        "statusBar.background": "#FFFCF0",
        "statusBar.foreground": "#6F6E69",
        "statusBar.border": "#E6E4D9",
        "statusBar.debuggingBackground": "#BC5215",
        "statusBar.debuggingForeground": "#FFFCF0",
        "statusBar.noFolderBackground": "#FFFCF0",
        "statusBar.noFolderForeground": "#6F6E69",

        "tab.activeBackground": "#FFFCF0",
        "tab.activeForeground": "#100F0F",
        "tab.activeBorderTop": "#AD8301",
        "tab.inactiveBackground": "#F2F0E5",
        "tab.inactiveForeground": "#6F6E69",
        "tab.border": "#E6E4D9",
        "tab.hoverBackground": "#E6E4D9",
        "editorGroupHeader.tabsBackground": "#F2F0E5",
        "editorGroupHeader.tabsBorder": "#E6E4D9",
        "editorGroup.border": "#E6E4D9",

        "panel.background": "#F2F0E5",
        "panel.border": "#E6E4D9",
        "panelTitle.activeBorder": "#AD8301",
        "panelTitle.activeForeground": "#100F0F",
        "panelTitle.inactiveForeground": "#6F6E69",

        "terminal.foreground": "#100F0F",
        "terminal.background": "#FFFCF0",
        "terminal.ansiBlack": "#100F0F",
        "terminal.ansiRed": "#AF3029",
        "terminal.ansiGreen": "#66800B",
        "terminal.ansiYellow": "#AD8301",
        "terminal.ansiBlue": "#205EA6",
        "terminal.ansiMagenta": "#A02F6F",
        "terminal.ansiCyan": "#24837B",
        "terminal.ansiWhite": "#FFFCF0",
        "terminal.ansiBrightBlack": "#6F6E69",
        "terminal.ansiBrightRed": "#AF3029",
        "terminal.ansiBrightGreen": "#66800B",
        "terminal.ansiBrightYellow": "#AD8301",
        "terminal.ansiBrightBlue": "#205EA6",
        "terminal.ansiBrightMagenta": "#A02F6F",
        "terminal.ansiBrightCyan": "#24837B",
        "terminal.ansiBrightWhite": "#FFFCF0",

        "input.background": "#F2F0E5",
        "input.foreground": "#100F0F",
        "input.border": "#E6E4D9",
        "input.placeholderForeground": "#B7B5AC",
        "inputOption.activeBorder": "#205EA6",
        "inputOption.activeBackground": "#205EA630",
        "inputValidation.errorBackground": "#AF302930",
        "inputValidation.errorBorder": "#AF3029",
        "inputValidation.warningBackground": "#AD830130",
        "inputValidation.warningBorder": "#AD8301",
        "inputValidation.infoBackground": "#24837B30",
        "inputValidation.infoBorder": "#24837B",

        "dropdown.background": "#F2F0E5",
        "dropdown.foreground": "#100F0F",
        "dropdown.border": "#E6E4D9",

        "button.background": "#205EA6",
        "button.foreground": "#FFFCF0",
        "button.hoverBackground": "#205EA6E0",
        "button.secondaryBackground": "#E6E4D9",
        "button.secondaryForeground": "#100F0F",

        "badge.background": "#205EA6",
        "badge.foreground": "#FFFCF0",

        "scrollbar.shadow": "#100F0F15",
        "scrollbarSlider.background": "#CECDC380",
        "scrollbarSlider.hoverBackground": "#B7B5ACA0",
        "scrollbarSlider.activeBackground": "#6F6E69A0",

        "breadcrumb.foreground": "#6F6E69",
        "breadcrumb.focusForeground": "#100F0F",
        "breadcrumb.activeSelectionForeground": "#100F0F",
        "breadcrumbPicker.background": "#F2F0E5",

        "minimap.findMatchHighlight": "#5E409D60",
        "minimap.selectionHighlight": "#B7B5ACA0",
        "minimapGutter.addedBackground": "#66800B",
        "minimapGutter.deletedBackground": "#AF3029",
        "minimapGutter.modifiedBackground": "#205EA6",

        "peekView.border": "#E6E4D9",
        "peekViewEditor.background": "#F2F0E5",
        "peekViewEditorGutter.background": "#F2F0E5",
        "peekViewResult.background": "#F2F0E5",
        "peekViewResult.fileForeground": "#100F0F",
        "peekViewResult.lineForeground": "#6F6E69",
        "peekViewResult.matchHighlightBackground": "#AD830140",
        "peekViewResult.selectionBackground": "#B7B5AC",
        "peekViewResult.selectionForeground": "#100F0F",
        "peekViewTitle.background": "#E6E4D9",
        "peekViewTitleDescription.foreground": "#6F6E69",
        "peekViewTitleLabel.foreground": "#100F0F",

        "gitDecoration.addedResourceForeground": "#66800B",
        "gitDecoration.modifiedResourceForeground": "#205EA6",
        "gitDecoration.deletedResourceForeground": "#AF3029",
        "gitDecoration.renamedResourceForeground": "#24837B",
        "gitDecoration.untrackedResourceForeground": "#66800B",
        "gitDecoration.ignoredResourceForeground": "#B7B5AC",
        "gitDecoration.conflictingResourceForeground": "#BC5215",

        "debugToolBar.background": "#E6E4D9",
        "debugIcon.breakpointForeground": "#AF3029",
        "debugIcon.startForeground": "#66800B",
        "debugIcon.pauseForeground": "#AD8301",
        "debugIcon.stopForeground": "#AF3029",
        "debugIcon.stepOverForeground": "#205EA6",
        "debugIcon.stepIntoForeground": "#205EA6",
        "debugIcon.stepOutForeground": "#205EA6",
        "debugIcon.restartForeground": "#66800B",

        "notificationCenterHeader.background": "#E6E4D9",
        "notifications.background": "#E6E4D9",
        "notifications.foreground": "#100F0F",
        "notifications.border": "#CECDC3",
        "notificationsErrorIcon.foreground": "#AF3029",
        "notificationsWarningIcon.foreground": "#AD8301",
        "notificationsInfoIcon.foreground": "#205EA6",

        "settings.headerForeground": "#100F0F",
        "settings.modifiedItemIndicator": "#205EA6",

        "keybindingLabel.background": "#E6E4D9",
        "keybindingLabel.foreground": "#100F0F",
        "keybindingLabel.border": "#CECDC3"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": [
                "comment",
                "comment.block",
                "comment.block.documentation",
                "comment.line"
            ],
            "settings": {
                "foreground": "#B7B5AC",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Doc comment tags (@param, @return)",
            "scope": [
                "comment.block.documentation storage.type.class",
                "comment.block.documentation punctuation.definition",
                "comment.block.documentation variable.other",
                "keyword.other.documentation",
                "storage.type.class.jsdoc",
                "entity.name.type.instance.jsdoc"
            ],
            "settings": {
                "foreground": "#6F6E69"
            }
        },
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.other",
                "storage",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#66800B"
            }
        },
        {
            "name": "Operators and punctuation",
            "scope": [
                "keyword.operator",
                "keyword.operator.arithmetic",
                "keyword.operator.assignment",
                "keyword.operator.comparison",
                "keyword.operator.logical",
                "keyword.operator.ternary",
                "keyword.operator.spread",
                "keyword.operator.rest",
                "keyword.operator.type",
                "punctuation",
                "punctuation.definition.parameters",
                "punctuation.definition.array",
                "punctuation.definition.block",
                "punctuation.separator",
                "punctuation.terminator",
                "punctuation.accessor",
                "punctuation.section",
                "meta.brace",
                "storage.modifier.pointer",
                "storage.modifier.reference"
            ],
            "settings": {
                "foreground": "#6F6E69"
            }
        },
        {
            "name": "Functions",
            "scope": [
                "entity.name.function",
                "entity.name.method",
                "support.function",
                "meta.function-call entity.name.function",
                "meta.method-call entity.name.function"
            ],
            "settings": {
                "foreground": "#BC5215"
            }
        },
        {
            "name": "Function/method calls (semantic fallback)",
            "scope": ["meta.function-call", "meta.method-call"],
            "settings": {
                "foreground": "#100F0F"
            }
        },
        {
            "name": "Types and classes",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.namespace",
                "entity.name.enum",
                "entity.other.inherited-class",
                "support.type",
                "support.class",
                "support.type.builtin",
                "entity.name.type.primitive",
                "support.type.primitive",
                "storage.type.primitive",
                "storage.type.built-in",
                "keyword.type"
            ],
            "settings": {
                "foreground": "#AD8301"
            }
        },
        {
            "name": "Language builtins (this, self, true, false, null)",
            "scope": ["variable.language", "constant.language"],
            "settings": {
                "foreground": "#A02F6F"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "variable.other",
                "variable.other.readwrite",
                "variable.other.object",
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "Variable parameters",
            "scope": ["variable.parameter", "variable.parameter.function"],
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "Properties (default text, not highlighted)",
            "scope": [
                "variable.other.property",
                "variable.other.member",
                "support.variable.property",
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#100F0F"
            }
        },
        {
            "name": "Constants",
            "scope": [
                "constant",
                "constant.other",
                "variable.other.constant",
                "support.constant"
            ],
            "settings": {
                "foreground": "#AD8301"
            }
        },
        {
            "name": "Character constants",
            "scope": ["constant.character"],
            "settings": {
                "foreground": "#24837B"
            }
        },
        {
            "name": "Numbers",
            "scope": [
                "constant.numeric",
                "constant.numeric.integer",
                "constant.numeric.float",
                "constant.numeric.hex",
                "constant.numeric.octal",
                "constant.numeric.binary"
            ],
            "settings": {
                "foreground": "#5E409D"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "string.quoted.single",
                "string.quoted.double",
                "string.quoted.triple",
                "string.template"
            ],
            "settings": {
                "foreground": "#24837B"
            }
        },
        {
            "name": "Escape characters",
            "scope": [
                "constant.character.escape",
                "string.quoted constant.character.escape"
            ],
            "settings": {
                "foreground": "#24837B",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Regex",
            "scope": [
                "string.regexp",
                "string.regexp keyword.operator",
                "string.regexp keyword.other"
            ],
            "settings": {
                "foreground": "#A02F6F"
            }
        },
        {
            "name": "Template expression punctuation",
            "scope": [
                "punctuation.definition.template-expression",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#A02F6F"
            }
        },
        {
            "name": "Preprocessor / decorator / annotation",
            "scope": [
                "entity.name.function.preprocessor",
                "meta.preprocessor",
                "punctuation.definition.annotation",
                "storage.type.annotation",
                "meta.decorator",
                "meta.decorator entity.name.function"
            ],
            "settings": {
                "foreground": "#A02F6F"
            }
        },
        {
            "name": "Import keywords",
            "scope": [
                "keyword.control.import",
                "keyword.control.from",
                "keyword.control.export",
                "keyword.control.directive.include",
                "keyword.import",
                "keyword.other.import",
                "storage.modifier.import"
            ],
            "settings": {
                "foreground": "#AF3029"
            }
        },
        {
            "name": "Invalid",
            "scope": ["invalid", "invalid.illegal"],
            "settings": {
                "foreground": "#AF3029"
            }
        },
        {
            "name": "Tags (HTML/XML/JSX)",
            "scope": ["entity.name.tag", "punctuation.definition.tag"],
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "Tag attributes",
            "scope": [
                "entity.other.attribute-name.html",
                "entity.other.attribute-name.jsx",
                "entity.other.attribute-name.tsx"
            ],
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "Markup heading",
            "scope": ["markup.heading", "entity.name.section"],
            "settings": {
                "foreground": "#205EA6",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup heading markers (#, ##, etc.)",
            "scope": [
                "punctuation.definition.heading",
                "markup.heading punctuation.definition"
            ],
            "settings": {
                "foreground": "#6F6E69"
            }
        },
        {
            "name": "Markup bold",
            "scope": ["markup.bold", "punctuation.definition.bold"],
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markup italic",
            "scope": ["markup.italic", "punctuation.definition.italic"],
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup underline",
            "scope": "markup.underline",
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "name": "Markup strikethrough",
            "scope": "markup.strikethrough",
            "settings": {
                "fontStyle": "strikethrough"
            }
        },
        {
            "name": "Markup inline code",
            "scope": ["markup.inline.raw", "markup.fenced_code", "markup.raw"],
            "settings": {
                "foreground": "#5E409D"
            }
        },
        {
            "name": "Markup code block background",
            "scope": ["markup.fenced_code.block", "fenced_code.block.language"],
            "settings": {
                "foreground": "#100F0F"
            }
        },
        {
            "name": "Markup link text",
            "scope": ["markup.underline.link", "string.other.link"],
            "settings": {
                "foreground": "#24837B"
            }
        },
        {
            "name": "Markup link title / description",
            "scope": [
                "meta.link.inline markup.underline.link",
                "meta.image.inline markup.underline.link"
            ],
            "settings": {
                "foreground": "#24837B",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Markup list markers",
            "scope": [
                "punctuation.definition.list",
                "beginning.punctuation.definition.list"
            ],
            "settings": {
                "foreground": "#6F6E69"
            }
        },
        {
            "name": "Markup blockquote",
            "scope": ["markup.quote", "punctuation.definition.quote"],
            "settings": {
                "foreground": "#6F6E69",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markup inserted (diff)",
            "scope": "markup.inserted",
            "settings": {
                "foreground": "#66800B"
            }
        },
        {
            "name": "Markup deleted (diff)",
            "scope": "markup.deleted",
            "settings": {
                "foreground": "#AF3029"
            }
        },
        {
            "name": "Markup changed (diff)",
            "scope": "markup.changed",
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "JSON property names",
            "scope": [
                "support.type.property-name.json",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "YAML keys",
            "scope": "entity.name.tag.yaml",
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "TOML keys",
            "scope": ["keyword.key.toml", "support.type.property-name.toml"],
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "TOML table headers",
            "scope": [
                "entity.name.table.toml",
                "support.type.property-name.table.toml"
            ],
            "settings": {
                "foreground": "#AD8301"
            }
        },
        {
            "name": "CSS selectors",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.pseudo-class.css",
                "entity.other.attribute-name.pseudo-element.css"
            ],
            "settings": {
                "foreground": "#AD8301"
            }
        },
        {
            "name": "CSS properties",
            "scope": "support.type.property-name.css",
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "CSS values",
            "scope": [
                "support.constant.property-value.css",
                "support.constant.color.css",
                "support.constant.font-name.css"
            ],
            "settings": {
                "foreground": "#BC5215"
            }
        },
        {
            "name": "CSS units",
            "scope": "keyword.other.unit.css",
            "settings": {
                "foreground": "#5E409D"
            }
        },
        {
            "name": "Java type references (grammar uses storage.type for types, not keywords)",
            "scope": [
                "storage.type.java",
                "storage.type.generic.java",
                "storage.type.object.array.java"
            ],
            "settings": {
                "foreground": "#AD8301"
            }
        },
        {
            "name": "Nix attribute names",
            "scope": "entity.other.attribute-name.multipart.nix",
            "settings": {
                "foreground": "#205EA6"
            }
        },
        {
            "name": "Nix interpolation",
            "scope": "punctuation.section.interpolation.nix",
            "settings": {
                "foreground": "#A02F6F"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "function": "#BC5215",
        "function.declaration": "#BC5215",
        "method": "#BC5215",
        "method.declaration": "#BC5215",
        "variable": "#205EA6",
        "variable.declaration": "#205EA6",
        "variable.readonly": "#205EA6",
        "parameter": "#205EA6",
        "property": "#100F0F",
        "property.declaration": "#100F0F",
        "property.readonly": "#100F0F",
        "type": "#AD8301",
        "type.declaration": "#AD8301",
        "class": "#AD8301",
        "class.declaration": "#AD8301",
        "interface": "#AD8301",
        "interface.declaration": "#AD8301",
        "enum": "#AD8301",
        "enum.declaration": "#AD8301",
        "enumMember": "#AD8301",
        "namespace": "#AD8301",
        "keyword": "#66800B",
        "string": "#24837B",
        "number": "#5E409D",
        "operator": "#6F6E69",
        "comment": { "foreground": "#B7B5AC", "fontStyle": "italic" },
        "regexp": "#A02F6F",
        "decorator": "#A02F6F",
        "macro": "#24837B",
        "typeParameter": "#AD8301",
        "selfKeyword": "#A02F6F",
        "builtinType": "#AD8301"
    }
}
