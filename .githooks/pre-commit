#!/usr/bin/env bash
set -euo pipefail

# Only check staged files — everything else was already formatted.
mapfile -t files < <(git diff --cached --name-only --diff-filter=d)
[[ ${#files[@]} -eq 0 ]] && exit 0

# Prefer treefmt from devshell (instant); fall back to nix fmt (slow but always works).
if command -v treefmt &>/dev/null; then
    fmt_cmd=(treefmt --ci -- "${files[@]}")
else
    fmt_cmd=(nix fmt -- --ci "${files[@]}")
fi

if ! "${fmt_cmd[@]}"; then
    echo ""
    echo "Pre-commit: staged files are not formatted."
    echo "Run 'just fmt' and restage your changes."
    exit 1
fi
